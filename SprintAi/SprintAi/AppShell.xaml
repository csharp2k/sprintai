<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SprintAi.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SprintAi"
    xmlns:views="clr-namespace:SprintAi.Views">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <!-- Register pages for direct navigation -->
    <ShellContent Route="following" ContentTemplate="{DataTemplate views:FollowingPage}" />
    <ShellContent Route="explore" ContentTemplate="{DataTemplate views:ExplorePage}" />
    <ShellContent Route="nearby" ContentTemplate="{DataTemplate views:NearbyPage}" />

</Shell>
