<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SprintAi.ViewModels"
             xmlns:models="clr-namespace:SprintAi.Models"
             x:Class="SprintAi.MainPage">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Top Navigation Bar moved to HomePage -->

        <!-- Category Scroll Bar moved to HomePage -->

        <!-- Main Content Feed area (will be swapped in-code) -->
        <ContentView Grid.Row="2" x:Name="ContentHolder" />

        <!-- Bottom Navigation Bar (shared) -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,*,*,*" Padding="10" BackgroundColor="LightGray">
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="home_active.png" WidthRequest="24" HeightRequest="24" />
                <Label x:Name="HomeLabel" Text="Home" FontSize="12" FontAttributes="Bold" TextColor="Black" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMarketTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="market.png" WidthRequest="24" HeightRequest="24" />
                <Label x:Name="MarketLabel" Text="Market" FontSize="12" TextColor="Gray" FontAttributes="None" />
            </VerticalStackLayout>
            <Button Grid.Column="2" Text="+" BackgroundColor="Red" TextColor="White" WidthRequest="50" HeightRequest="50" CornerRadius="25" VerticalOptions="Center" />
            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMessagesTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Grid>
                    <Image Source="messages.png" WidthRequest="24" HeightRequest="24" />
                    <Label Text="1" BackgroundColor="Red" TextColor="White" FontSize="10" HorizontalOptions="End" VerticalOptions="Start" Margin="15,0,0,15" Padding="3" />
                </Grid>
                <Label x:Name="MessagesLabel" Text="Messages" FontSize="12" TextColor="Gray" FontAttributes="None" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMeTapped" />
                </VerticalStackLayout.GestureRecognizers>
                <Image Source="profile.png" WidthRequest="24" HeightRequest="24" />
                <Label x:Name="MeLabel" Text="Me" FontSize="12" TextColor="Gray" FontAttributes="None" />
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
