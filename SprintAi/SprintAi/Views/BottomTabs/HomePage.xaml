<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SprintAi.Views.BottomTabs.HomePage">

<StackLayout Padding="10">
    <!-- Top Navigation Bar moved here -->
    <Grid ColumnDefinitions="Auto,*,Auto" Padding="10" BackgroundColor="LightGray">
        <Image Grid.Column="0" Source="hamburger.png" WidthRequest="24" HeightRequest="24" />
        <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="20">
            <Label Text="Following" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Following_Tapped" />
                </Label.GestureRecognizers>
            </Label>
            <Label Text="Explore" FontAttributes="Bold" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Explore_Tapped" />
                </Label.GestureRecognizers>
            </Label>
            <Label Text="Nearby" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Nearby_Tapped" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>
        <Image Grid.Column="2" Source="search.png" WidthRequest="24" HeightRequest="24" />
    </Grid>

    <!-- Category Scroll Bar moved to ExplorePage -->

    <!-- Inner content area that will display Following/Explore/Nearby without full navigation -->
    <ContentView x:Name="InnerContentHolder" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" />

</StackLayout>

</ContentPage>