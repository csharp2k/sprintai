<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SprintAi.Models"
             x:Class="SprintAi.Views.ExplorePage">

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Category Scroll Bar moved from HomePage -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" BackgroundColor="White">
            <HorizontalStackLayout Spacing="15" Padding="10">
                <Label x:Name="ForYouLabel" Text="For You" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnForYouTapped" NumberOfTapsRequired="1" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="VideoLabel" Text="Video">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnVideoTapped" NumberOfTapsRequired="1" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="LiveLabel" Text="Live">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLiveTapped" NumberOfTapsRequired="1" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="SeriesLabel" Text="Series">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSeriesTapped" NumberOfTapsRequired="1" />
                    </Label.GestureRecognizers>
                </Label>
                <Label x:Name="FashionLabel" Text="Fashion">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFashionTapped" NumberOfTapsRequired="1" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Host category content here so taps keep the category bar and other UI visible -->
        <ContentView Grid.Row="2" x:Name="CategoryContent" BackgroundColor="Transparent">
            <!-- content will be loaded from code-behind -->
        </ContentView>
    </Grid>

</ContentPage>