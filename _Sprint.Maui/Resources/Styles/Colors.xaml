<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Colors -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#3B1F94</Color>
    <Color x:Key="PrimaryLight">#8B5CF6</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="Accent">#F7B548</Color>

    <!-- Text Colors -->
    <Color x:Key="PrimaryTextColor">#1F1F1F</Color>
    <Color x:Key="SecondaryTextColor">#6B6B6B</Color>
    <Color x:Key="TertiaryTextColor">#9B9B9B</Color>

    <!-- Background Colors -->
    <Color x:Key="PageBackgroundColor">#F5F5F5</Color>
    <Color x:Key="CardBackgroundColor">White</Color>
    <Color x:Key="SeparatorColor">#E5E5E5</Color>

    <!-- Status Colors -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- Semantic Colors -->
    <Color x:Key="Red">#F44336</Color>
    <Color x:Key="Green">#4CAF50</Color>
    <Color x:Key="Blue">#2196F3</Color>
    <Color x:Key="Yellow">#FFEB3B</Color>

</ResourceDictionary>